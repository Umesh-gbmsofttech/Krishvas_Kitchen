{
  "expo": {
    "name": "KrishvasKitchen",
    "slug": "KrishvasKitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/KrishvasKitchen_transparent.png",
    "scheme": "krishvaskitchen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.krishvas.kitchen",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/KrishvasKitchen_transparent.png",
        "monochromeImage": "./assets/images/KrishvasKitchen_transparent.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.krishvas.kitchen",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/KrishvasKitchen_transparent.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-location",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/KrishvasKitchen_transparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "buildNumber": "1",
      "apiBaseUrl": "https://krishvas-kitchen-server.onrender.com",
      "githubRepo": "Umesh-gbmsofttech/Krishvas_Kitchen",
      "stripePublishableKey": "pk_test_51T7VfSCJp2gc0N3ig2nlS2pEXpfYzhpqb3oBsXclr2UbCTFBZ9crqovAL4uk7U4T9Xkr1Aolp6Bwt2lwfXs6hHGW00hhlpmNng",
      "router": {},
      "eas": {
        "projectId": "c7323ea7-d6f0-4536-bf4c-b2bb1b898570"
      }
    }
  }
}
